<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Petstore API Regression Test Suite" verbose="1" parallel="tests" thread-count="2">
    
    <listeners>
        <listener class-name="com.example.base.BaseTest"/>
        <listener class-name="com.example.listeners.AllureListener"/>
    </listeners>
    
    <test name="Regression Tests" group-by-instances="true">
        <groups>
            <run>
                <include name="regression"/>
                <exclude name="smoke"/>
            </run>
        </groups>
        
        <packages>
            <package name="com.example.regression"/>
        </packages>
    </test>
    
    <test name="Negative Tests" group-by-instances="true">
        <groups>
            <run>
                <include name="negative"/>
                <exclude name="smoke"/>
            </run>
        </groups>
        
        <packages>
            <package name="com.example.negative"/>
        </packages>
    </test>
    
</suite>
